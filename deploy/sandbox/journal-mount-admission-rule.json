{
  "api_version": "kapsel.sandbox.gate1/v1",
  "request_username": "system:serviceaccount:kapsel-sandbox-system:sandbox-scheduler",
  "matched_kind": "Pod",
  "matched_namespace": "kapsel-sandbox-runners",
  "required_run_label": "kapsel.dev/sandbox-run-id",
  "canonical_template": "journal-volume-template.json#/runner_pod_template",
  "comparison": "complete_rendered_object_equality",
  "undeclared_fields": "deny",
  "writable_volume": {
    "name": "gateway-state",
    "claim_name_template": "journal-${RUN_ID}",
    "mount_path": "/var/lib/kapsel-runner/state"
  },
  "read_only_channels": [
    "operator-composition",
    "kubernetes-controller",
    "authorization-inputs",
    "receipt-signing",
    "receipt-handoff"
  ],
  "explicitly_denied_mutations": [
    "metadata",
    "service_account",
    "runtime_class",
    "command",
    "arguments",
    "environment",
    "environment_from",
    "image",
    "pod_security_context",
    "container_security_context",
    "volume",
    "volume_source",
    "volume_mount",
    "secret_projection",
    "config_map_projection",
    "token_projection",
    "writable_channel"
  ],
  "enforcement_status": "normalized_gate1_model_live_kubernetes_admission_unproved"
}
