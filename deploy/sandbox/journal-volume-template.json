{
  "api_version": "kapsel.sandbox.gate1/v1",
  "one_claim_per_run": true,
  "target_namespace_template": "sandbox-${RUN_ID}",
  "claim": {
    "apiVersion": "v1",
    "kind": "PersistentVolumeClaim",
    "metadata": {
      "name": "journal-${RUN_ID}",
      "namespace": "kapsel-sandbox-runners",
      "labels": {
        "kapsel.dev/sandbox-run-id": "${RUN_ID}",
        "kapsel.dev/storage-purpose": "gateway-journal"
      }
    },
    "spec": {
      "accessModes": [
        "ReadWriteOncePod"
      ],
      "resources": {
        "requests": {
          "storage": "1Gi"
        }
      },
      "storageClassName": "${GATE2_STORAGE_CLASS}"
    }
  },
  "runner_pod_template": {
    "apiVersion": "v1",
    "kind": "Pod",
    "metadata": {
      "name": "runner-${RUN_ID}",
      "namespace": "kapsel-sandbox-runners",
      "labels": {
        "kapsel.dev/sandbox-run-id": "${RUN_ID}",
        "kapsel.dev/storage-purpose": "gateway-journal-writer"
      }
    },
    "spec": {
      "automountServiceAccountToken": false,
      "enableServiceLinks": false,
      "serviceAccountName": "runner-${RUN_ID}",
      "runtimeClassName": "${GATE2_RUNTIME_CLASS}",
      "restartPolicy": "Never",
      "securityContext": {
        "runAsNonRoot": true,
        "runAsUser": 65532,
        "runAsGroup": 65532,
        "fsGroup": 65532,
        "seccompProfile": {
          "type": "RuntimeDefault"
        }
      },
      "containers": [
        {
          "name": "native-runner",
          "image": "${KAPSEL_SANDBOX_IMAGE_DIGEST}",
          "command": [
            "/usr/local/bin/kapsel-sandbox"
          ],
          "args": [
            "${GATE2_RUNNER_SUBCOMMAND}",
            "--operator-composition",
            "/var/run/kapsel-runner/composition/operator-configuration.json",
            "--receipt-handoff",
            "/var/run/kapsel-runner/receipt-handoff"
          ],
          "env": [],
          "envFrom": [],
          "securityContext": {
            "allowPrivilegeEscalation": false,
            "capabilities": {
              "drop": [
                "ALL"
              ]
            },
            "readOnlyRootFilesystem": true,
            "runAsNonRoot": true
          },
          "volumeMounts": [
            {
              "name": "gateway-state",
              "mountPath": "/var/lib/kapsel-runner/state",
              "readOnly": false
            },
            {
              "name": "operator-composition",
              "mountPath": "/var/run/kapsel-runner/composition",
              "readOnly": true
            },
            {
              "name": "kubernetes-controller",
              "mountPath": "/var/run/kapsel-runner/kubernetes",
              "readOnly": true
            },
            {
              "name": "authorization-inputs",
              "mountPath": "/var/run/kapsel-runner/authorization",
              "readOnly": true
            },
            {
              "name": "receipt-signing",
              "mountPath": "/var/run/kapsel-runner/receipt-signing",
              "readOnly": true
            },
            {
              "name": "receipt-handoff",
              "mountPath": "/var/run/kapsel-runner/receipt-handoff",
              "readOnly": true
            }
          ]
        }
      ],
      "volumes": [
        {
          "name": "gateway-state",
          "persistentVolumeClaim": {
            "claimName": "journal-${RUN_ID}",
            "readOnly": false
          }
        },
        {
          "name": "operator-composition",
          "configMap": {
            "name": "runner-composition-${RUN_ID}",
            "defaultMode": 288
          }
        },
        {
          "name": "kubernetes-controller",
          "projected": {
            "defaultMode": 288,
            "sources": [
              {
                "serviceAccountToken": {
                  "audience": "${GATE2_KUBERNETES_AUDIENCE}",
                  "expirationSeconds": 600,
                  "path": "token"
                }
              },
              {
                "configMap": {
                  "name": "runner-kubernetes-${RUN_ID}",
                  "items": [
                    {
                      "key": "api-server",
                      "path": "api-server"
                    }
                  ]
                }
              },
              {
                "configMap": {
                  "name": "kube-root-ca.crt",
                  "items": [
                    {
                      "key": "ca.crt",
                      "path": "ca.crt"
                    }
                  ]
                }
              },
              {
                "downwardAPI": {
                  "items": [
                    {
                      "path": "namespace",
                      "fieldRef": {
                        "apiVersion": "v1",
                        "fieldPath": "metadata.namespace"
                      }
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "authorization-inputs",
          "projected": {
            "defaultMode": 288,
            "sources": [
              {
                "secret": {
                  "name": "runner-grant-${RUN_ID}",
                  "items": [
                    {
                      "key": "signed-grant.json",
                      "path": "signed-grant.json"
                    }
                  ]
                }
              },
              {
                "configMap": {
                  "name": "runner-trust-${RUN_ID}",
                  "items": [
                    {
                      "key": "trust.json",
                      "path": "trust.json"
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "receipt-signing",
          "projected": {
            "defaultMode": 288,
            "sources": [
              {
                "secret": {
                  "name": "runner-receipt-signing-${RUN_ID}",
                  "items": [
                    {
                      "key": "seed",
                      "path": "seed"
                    },
                    {
                      "key": "key-id",
                      "path": "key-id"
                    }
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "receipt-handoff",
          "projected": {
            "defaultMode": 288,
            "sources": [
              {
                "secret": {
                  "name": "runner-receipt-handoff-${RUN_ID}",
                  "items": [
                    {
                      "key": "credential",
                      "path": "credential"
                    }
                  ]
                }
              },
              {
                "configMap": {
                  "name": "runner-receipt-handoff-${RUN_ID}",
                  "items": [
                    {
                      "key": "endpoint",
                      "path": "endpoint"
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  },
  "authorized_mount": {
    "request_username": "system:serviceaccount:kapsel-sandbox-system:sandbox-scheduler",
    "namespace": "kapsel-sandbox-runners",
    "service_account_name_template": "runner-${RUN_ID}",
    "principal_template": "system:serviceaccount:kapsel-sandbox-runners:runner-${RUN_ID}",
    "writable_volume": "gateway-state",
    "writable_mount_path": "/var/lib/kapsel-runner/state"
  },
  "required_live_proof": [
    "exact_runner_identity_is_the_only_authorized_mount_consumer",
    "second_pod_mount_is_denied_including_on_the_same_node",
    "runner_replacement_reuses_the_same_volume_and_operation_identity",
    "api_other_runner_and_target_workload_cannot_read_or_mount_the_volume",
    "projected_authority_is_bound_to_the_exact_runner_and_denied_to_every_other_identity",
    "receipt_handoff_installs_exact_frozen_bytes_without_re_signing_or_replacement",
    "terminal_retention_deletes_the_claim_within_the_contract_window"
  ]
}
